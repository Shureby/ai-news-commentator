# ── LLM Backend ──
LLM_PROVIDER=anthropic                     # anthropic / openai / openai_compat
LLM_MODEL=claude-sonnet-4-6                # Model ID

# Anthropic (API key required; base URL optional for proxy/routing)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_BASE_URL=

# OpenAI (API key required; base URL optional for proxy/routing)
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_BASE_URL=

# Local models: llama.cpp / vllm / ollama / LM Studio (all use openai_compat provider)
# ollama default:      http://localhost:11434/v1
# llama.cpp default:   http://localhost:8080/v1
# vllm default:        http://localhost:8000/v1
# LM Studio default:   http://localhost:1234/v1
LLM_API_KEY=not-needed
LLM_BASE_URL=http://localhost:11434/v1

# ── WeChat Official Account (optional) ──
WECHAT_APP_ID=wx_xxxxxxxxx
WECHAT_APP_SECRET=xxxxxxxxxxxxx
